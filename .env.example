# =====================================================
# API (apps/api)
# =====================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/aicompta_dev
REDIS_URL=redis://localhost:6379

# Stockage S3-compatible (MinIO en dev, R2 en prod)
R2_ENDPOINT=http://localhost:9000
R2_BUCKET=aicompta-dev
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_REGION=auto
R2_FORCE_PATH_STYLE=true

# Auth
AUTH_SECRET=change_me_change_me_change_me_32chars
AUTH_BASE_URL=http://localhost:3001

# Email
RESEND_API_KEY=
RESEND_INBOUND_SECRET=
RESEND_FROM=AI Compta <noreply@aicompta.app>

# IA — Anthropic (laissez vide pour activer l'extracteur MOCK)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_EXTRACTION=claude-sonnet-4-5
ANTHROPIC_MODEL_CLASSIFIER=claude-haiku-4-5

# Limites
MAX_UPLOAD_BYTES=26214400
AI_CONFIDENCE_THRESHOLD=0.85
AI_TOKEN_BUDGET_MONTHLY=1000000

# Logs / Server
LOG_LEVEL=info
PORT=3001
NODE_ENV=development

# =====================================================
# Web (apps/web)
# =====================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
