# Environment
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aicompta_dev

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aicompta-documents

# Authentication
AUTH_SECRET=your-super-secret-key-min-32-chars-long-change-this-in-production
AUTH_BASE_URL=http://localhost:3001

# Email (Resend)
RESEND_API_KEY=
RESEND_INBOUND_SECRET=
RESEND_FROM=AI Compta <noreply@aicompta.app>

# AI - Claude (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096

# Upload & AI Configuration
MAX_UPLOAD_BYTES=26214400
AI_CONFIDENCE_THRESHOLD=0.85

# Public URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
